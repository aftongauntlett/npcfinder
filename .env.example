# Copy this file to .env.local and fill in real values.
# Do not commit .env.local.

# -----------------------------------------------------------------------------
# Supabase Core
# -----------------------------------------------------------------------------
# Get API values from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Optional aliases used by scripts/tests
SUPABASE_URL=your_supabase_url_here
ANON_KEY=your_supabase_anon_key_here
SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Supabase project linking (CLI)
VITE_SUPABASE_PROJECT_REF=your_project_ref_here
SUPABASE_DB_PASSWORD=your_db_password_here

# Optional admin id used by some local admin tooling
VITE_ADMIN_USER_ID=your_admin_user_uuid_here

# -----------------------------------------------------------------------------
# Backend Security Runbook Test Users (local-only)
# -----------------------------------------------------------------------------
# Used by:
# - npm run security:seed-test-users
# - npm run test:backend-security
# - npm run test:backend-security:seeded
USER_A_EMAIL=security-user-a@example.com
USER_A_PASSWORD=replace_with_strong_password_a
USER_B_EMAIL=security-user-b@example.com
USER_B_PASSWORD=replace_with_strong_password_b
USER_C_EMAIL=security-user-c@example.com
USER_C_PASSWORD=replace_with_strong_password_c

# -----------------------------------------------------------------------------
# Third-Party API Keys
# -----------------------------------------------------------------------------
VITE_TMDB_API_KEY=your_tmdb_api_key_here
VITE_RAWG_API_KEY=your_rawg_api_key_here
VITE_GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here
VITE_OMDB_API_KEY=your_omdb_api_key_here

# Music lookup uses iTunes Search API and does not require a key.

# -----------------------------------------------------------------------------
# Optional Services
# -----------------------------------------------------------------------------
VITE_SENTRY_DSN=your_sentry_dsn_here
KEEP_ALIVE_SECRET=your_keep_alive_secret_here
SNYK_TOKEN=your_snyk_token_here

# To link your Supabase project for CLI commands:
# npx supabase link --project-ref <VITE_SUPABASE_PROJECT_REF> --password <SUPABASE_DB_PASSWORD>
