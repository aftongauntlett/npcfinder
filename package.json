{
  "name": "npc-finder",
  "private": true,
  "version": "1.2.0",
  "description": "Invite-only media archive and social curation for trusted friends — movies, TV, books, games, and music.",
  "author": "Afton Gauntlett",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage --run",
    "test:backend-security": "RUN_BACKEND_SECURITY_TESTS=true vitest --run tests/backendSecurityRunbook.test.ts",
    "security:seed-test-users": "tsx scripts/seed-backend-security-users.ts",
    "test:backend-security:seeded": "npm run security:seed-test-users && npm run test:backend-security",
    "kill:tests": "pkill -f 'vitest' || true",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "security:check": "npm audit --audit-level=moderate && npm run lint && npm run test -- --run",
    "lighthouse": "lighthouse http://localhost:5173 --view --only-categories=performance,accessibility,best-practices,seo",
    "lighthouse:ci": "lighthouse http://localhost:5173 --output=json --output-path=./lighthouse-report.json --only-categories=performance,accessibility,best-practices,seo",
    "admin:configure": "node scripts/configure-super-admin.js",
    "// DATABASE": "── Production Database (via linked CLI project) ─────────────────────",
    "// db:link": "Link: npx supabase link --project-ref <PROJECT_REF> (uses .env.local)",
    "// db:warning": "⚠️  All db:* commands target PRODUCTION (no local dev database)",
    "db:push": "npx supabase db push",
    "db:pull": "npx supabase db pull",
    "db:diff": "npx supabase db diff --linked",
    "db:migration:list": "npx supabase migration list",
    "db:migration:new": "npx supabase migration new",
    "cache:warm:media-details": "tsx scripts/warm-media-details-cache.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/react": "^8.0.0",
    "@supabase/supabase-js": "^2.75.0",
    "@tanstack/react-query": "^5.90.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.22",
    "lucide-react": "^0.544.0",
    "react": "^19.2.3",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.3",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.11.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.1.12",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^16.3.0",
    "jsdom": "^27.0.0",
    "knip": "^5.72.0",
    "lighthouse": "^12.8.2",
    "postcss": "^8.5.6",
    "supabase": "^2.51.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  }
}
